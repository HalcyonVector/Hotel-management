{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "maven.build",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "compile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "echo": true
            },
            "problemMatcher": [
                "$java"
            ]
        },
        {
            "label": "maven.test",
            "type": "shell",
            "command": "mvn",
            "args": [
                "test"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "echo": true
            },
            "problemMatcher": [
                "$java"
            ]
        },
        {
            "label": "maven.run",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "javafx:run"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "echo": true
            },
            "problemMatcher": [
                "$java"
            ]
        },
        {
            "label": "maven.package",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
